# -----------------------------
# MediaFlow production env file
# Copy to .env next to docker-compose.yml
# -----------------------------

# Project behavior
COMPOSE_PROJECT_NAME=mediaflow
MEDIAFLOW_ENV=prod
MEDIAFLOW_APP_NAME=MediaFlow Backend

# Ports exposed on Ubuntu host
MEDIAFLOW_FRONTEND_PORT=8080
MEDIAFLOW_BACKEND_PORT=18080

# Frontend runtime API base.
# Recommended: /api (frontend nginx will proxy to backend container)
MEDIAFLOW_API_BASE=/api

# Security
# Generate with:
# openssl rand -base64 48
MEDIAFLOW_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
MEDIAFLOW_JWT_ALGORITHM=HS256
MEDIAFLOW_JWT_EXP_MINUTES=60

# CORS (only needed for browser calls directly to backend host:port)
# If your UI is served from https://mediaflow.example.com, set:
# MEDIAFLOW_CORS_ORIGINS=https://mediaflow.example.com
MEDIAFLOW_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Host persistent storage root (outside code directory)
# Suggested homelab layout:
# /srv/services/mediaflow    -> git repo + compose
# /srv/data/mediaflow        -> persistent app data
HOST_MEDIAFLOW_DATA_ROOT=/srv/data/mediaflow

# Paths inside backend container
MEDIAFLOW_USERS_FILE=/var/lib/mediaflow/data/users.json
MEDIAFLOW_DB_PATH=/var/lib/mediaflow/data/app.sqlite
MEDIAFLOW_OUTPUTS_DIR=/var/lib/mediaflow/outputs
MEDIAFLOW_COOKIES_FILE=/var/lib/mediaflow/secrets/cookies.txt

# Cleanup
MEDIAFLOW_OUTPUTS_TTL_HOURS=24
# Set 0 to disable minutes override and use MEDIAFLOW_OUTPUTS_TTL_HOURS.
MEDIAFLOW_OUTPUTS_TTL_MINUTES=0
MEDIAFLOW_OUTPUTS_CLEANUP_INTERVAL_MINUTES=60

# Capacity / retries
MEDIAFLOW_MAX_PARALLEL_JOBS=2
MEDIAFLOW_QUEUE_MAX_SIZE=50
MEDIAFLOW_MAX_ACTIVE_JOBS_PER_USER=2
MEDIAFLOW_DEDUP_WINDOW_MINUTES=60
MEDIAFLOW_MAX_ATTEMPTS=4
MEDIAFLOW_BACKOFF_BASE_SECONDS=2.0
MEDIAFLOW_YTDLP_RETRIES=0
MEDIAFLOW_YTDLP_FRAGMENT_RETRIES=0
MEDIAFLOW_YTDLP_EXTRACTOR_RETRIES=0
# Docker image provides Node here. Leave empty only if you want yt-dlp to search PATH.
MEDIAFLOW_NODE_PATH=/usr/bin/node
# Enable remote challenge solver components when YouTube requires them.
# Accepted values: ejs:github, true (alias for ejs:github), or empty/false to disable.
MEDIAFLOW_YTDLP_REMOTE_COMPONENTS=ejs:github

# Media options
MEDIAFLOW_EMBED_METADATA=true
MEDIAFLOW_EMBED_THUMBNAIL=true
MEDIAFLOW_THUMBNAIL_CONVERT_FORMAT=jpg
