# General Settings
ENV=dev
APP_NAME="MediaFlow Backend"

# Security and Authentication
JWT_SECRET=CHANGE_ME_NOW
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=60

# File Paths
USERS_FILE=data/users.json
DB_PATH=data/app.sqlite
OUTPUTS_DIR=outputs

# Performance and Queue Settings
MAX_PARALLEL_JOBS=2
QUEUE_MAX_SIZE=50