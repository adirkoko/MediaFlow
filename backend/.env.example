# General Settings
ENV=dev
APP_NAME="MediaFlow Backend"
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security and Authentication
JWT_SECRET=CHANGE_ME_NOW
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=60

# File Paths
# USERS_FILE is only used by the legacy users.json migration script.
USERS_FILE=data/users.json
DB_PATH=data/app.sqlite
OUTPUTS_DIR=outputs
OUTPUTS_TTL_HOURS=24
# Set 0 to disable minutes override and use OUTPUTS_TTL_HOURS.
OUTPUTS_TTL_MINUTES=0
OUTPUTS_CLEANUP_INTERVAL_MINUTES=60

# Path to your master cookies file (e.g., bin/cookies.txt)
COOKIES_FILE=bin/cookies.txt

# Performance and Queue Settings
MAX_PARALLEL_JOBS=2
QUEUE_MAX_SIZE=50

# Quota and Stability
MAX_ACTIVE_JOBS_PER_USER=2
DEDUP_WINDOW_MINUTES=60
LOGIN_MAX_FAILED_PER_USERNAME=5
LOGIN_MAX_FAILED_PER_IP=20
LOGIN_WINDOW_MINUTES=10
LOGIN_BLOCK_MINUTES=15
JOB_CREATE_RATE_LIMIT_PER_MINUTE=20
JOB_PREVIEW_RATE_LIMIT_PER_MINUTE=30
REGISTRATION_REQUESTS_ENABLED=true
REGISTRATION_RATE_LIMIT_PER_IP_PER_HOUR=5
REGISTRATION_RATE_LIMIT_PER_IP_PER_DAY=20
REGISTRATION_MAX_PENDING_PER_IP=3
REGISTRATION_MESSAGE_MAX_LENGTH=500

# Retry / Backoff Settings
MAX_ATTEMPTS=4
BACKOFF_BASE_SECONDS=2.0
YTDLP_RETRIES=0
YTDLP_FRAGMENT_RETRIES=0
YTDLP_EXTRACTOR_RETRIES=0

# Media Features
EMBED_METADATA=True
EMBED_THUMBNAIL=True
THUMBNAIL_CONVERT_FORMAT=jpg
