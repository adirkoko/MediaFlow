# General Settings
ENV=dev
APP_NAME="MediaFlow Backend"
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security and Authentication
JWT_SECRET=CHANGE_ME_NOW
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=60

# File Paths
USERS_FILE=data/users.json
DB_PATH=data/app.sqlite
OUTPUTS_DIR=outputs
OUTPUTS_TTL_HOURS=24
# Set 0 to disable minutes override and use OUTPUTS_TTL_HOURS.
OUTPUTS_TTL_MINUTES=0
OUTPUTS_CLEANUP_INTERVAL_MINUTES=60

# Path to your master cookies file (e.g., bin/cookies.txt)
COOKIES_FILE=bin/cookies.txt

# Performance and Queue Settings
MAX_PARALLEL_JOBS=2
QUEUE_MAX_SIZE=50

# Quota and Stability
MAX_ACTIVE_JOBS_PER_USER=2
DEDUP_WINDOW_MINUTES=60

# Retry / Backoff Settings
MAX_ATTEMPTS=4
BACKOFF_BASE_SECONDS=2.0
YTDLP_RETRIES=0
YTDLP_FRAGMENT_RETRIES=0
YTDLP_EXTRACTOR_RETRIES=0

# Media Features
EMBED_METADATA=True
EMBED_THUMBNAIL=True
THUMBNAIL_CONVERT_FORMAT=jpg
